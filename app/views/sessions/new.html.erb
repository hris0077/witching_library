<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="card bg-dark border-secondary hut-glow">
        <div class="card-body p-5">
          <div class="text-center mb-4">
            <i class="bi bi-house-heart-fill display-4" style="color: #d4af37;"></i>
            <h2 class="mystic-text mt-2">Enter the Hut</h2>
            <p class="text-white small">Prove your identity to the ancient tomes.</p>
          </div>

          <%= form_with url: session_path, local: true do |f| %>
            <div class="mb-3">
              <%= f.label :email_address, "Your True Name", class: "form-label text-white" %>
              <%= f.email_field :email_address, class: "form-control form-control-lg rounded-5 bg-dark", placeholder: "scholar@archive.com", autofocus: true %>
            </div>

            <div class="mb-4">
              <%= f.label :password, "Secret Sigil", class: "form-label text-white" %>
              <%= f.password_field :password, class: "form-control form-control-lg rounded-5 bg-dark", placeholder: "••••••••" %>
            </div>

            <div class="d-grid">
              <%= f.submit "Cross the Threshold", class: "btn btn-primary btn-lg text-white hut-glow" %>
            </div>
          <% end %>

          <div class="text-center mt-4">
            <%= link_to "Forgot your sigil?", new_password_path, class: "text-white small" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>