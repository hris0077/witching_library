<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="card bg-dark border-secondary hut-glow">
        <div class="card-body p-5">
          <div class="text-center mb-4">
            <i class="bi bi-bookmark-star-fill display-4" style="color: #d4af37;"></i>
            <h2 class="mystic-text mt-2">Inscribe Your Name</h2>
            <p class="hut-subtle small">Join the archive. The hut remembers those who seek wisely.</p>
          </div>

          <%= form_with model: @user, url: registration_path, local: true do |f| %>
            <div class="mb-3">
              <%= f.label :email_address, "Your True Name", class: "form-label text-secondary" %>
              <%= f.email_field :email_address, class: "form-control form-control-lg rounded-5 bg-dark text-secondary", placeholder: "scholar@archive.com", autofocus: true %>
            </div>

            <div class="mb-3">
              <%= f.label :first_name, "Given Name", class: "form-label text-secondary" %>
              <%= f.text_field :first_name, class: "form-control form-control-lg rounded-5 bg-dark text-secondary", placeholder: "Elena" %>
            </div>

            <div class="mb-3">
              <%= f.label :last_name, "House Name", class: "form-label text-secondary" %>
              <%= f.text_field :last_name, class: "form-control form-control-lg rounded-5 bg-dark text-secondary", placeholder: "Vasilisa" %>
            </div>

            <div class="mb-3">
              <%= f.label :timezone, "Realm of Dwelling", class: "form-label text-secondary" %>
              <%= f.time_zone_select :timezone, nil, { default: "UTC" }, { class: "form-select form-select-lg rounded-5 bg-dark" } %>
              <small class="text-secondary">Where does the hut find you?</small>
            </div>

            <div class="mb-4">
              <%= f.label :password, "Secret Sigil", class: "form-label text-secondary" %>
              <%= f.password_field :password, class: "form-control form-control-lg rounded-5 bg-dark text-secondary", placeholder: "••••••••" %>
            </div>

            <div class="mb-4">
              <%= f.label :password_confirmation, "Echo the Sigil", class: "form-label text-secondary" %>
              <%= f.password_field :password_confirmation, class: "form-control form-control-lg rounded-5 bg-dark text-secondary", placeholder: "••••••••" %>
            </div>
            <div class="d-grid">
              <%= f.submit "Seal the Covenant", class: "btn btn-primary btn-lg text-white hut-glow" %>
            </div>
          <% end %>

          <div class="text-center mt-4">
            <span class="hut-subtle small">Already inscribed?</span>
            <%= link_to "Enter the Hut", new_session_path, class: "text-primary small fw-bold" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
