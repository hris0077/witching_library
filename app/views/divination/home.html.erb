<div class="container py-5">
  <div class="text-center mb-5">
    <h1 class="display-4 mystic-text mb-3">The Hut Remembers What the World Forgets</h1>
    <p class="lead text-secondary mb-4">Step inside. Ask your question.</p>
  </div>

  <div class="row g-5">
    <!-- LEFT: The Form (No turbo_frame needed, Turbo intercepts it by default) -->
    <div class="col-md-5">
      <%= render "form" %>
    </div>

    <!-- RIGHT: The Results Area -->
    <div class="col-md-7">
      <div class="text-center py-5">
        <!--<i class="bi bi-house-heart display-1" style="color: #d4af37;"></i>-->
        <h4 class="mystic-text mt-3">Ask the Hut</h4>
        <p class="text-secondary">Enter your question. The oracle will consult the ancient tomes.</p>
      </div>
      <!-- TARGET 1: Oracle Response -->
      <div id="oracle-response-area">
        <% if @response.present? %>
          <%= render "oracle_response" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="row">
    <!-- TARGET 2: Books -->
      <div id="books-area">
      </div>
  </div>
</div>
