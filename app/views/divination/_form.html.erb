
  <div class="text-container p-4 d-flex flex-column justify-content-center h-100 mb-5">
    <h1>Welcome to The Hut - Baba Yaga's Library</h1>
    <p class="lead">
      Consult the oracle. The hut whispers wisdom from ancient tomes.
    </p>

    
    <!-- Form -->
    <div class="form-container text-center">
      <%= form_with url: ask_path, method: :post, data: { turbo_frame: "search_results" } do |f| %>
        <div class="my-4">
          <%= f.text_field :query, 
            class: "form-control form-control-lg rounded-5", 
            placeholder: "Search", 
            value: params[:query]
          %>
        </div>
        <div class="d-grid">
          <%= button_tag "Consult the Hut", 
            type: "submit", 
            class: "btn btn-primary btn-lg text-white"
          %>
        </div>
      <% end %>
    </div>
    <div class="mt-4">
      <p class="text-secondary small">
        <i class="bi bi-stars me-1 text-secondary"></i>
        Try: <em class="text-secondary">"magic spells"</em>, <em class="text-secondary">"ancient philosophy"</em>, or <em class="text-secondary">"matters of the heart"</em>
      </p>
    </div>
</div>

